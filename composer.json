{
    "name": "denny/laravel-sql-monitor",
    "description": "A comprehensive SQL query monitoring and analysis tool for Laravel development environments",
    "keywords": ["laravel", "sql", "monitor", "query", "n+1", "performance", "debug"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "phpmyadmin/sql-parser": "^5.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelSqlMonitor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelSqlMonitor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelSqlMonitor\\SqlMonitorServiceProvider"
            ],
            "aliases": {
                "SqlMonitor": "LaravelSqlMonitor\\Facades\\SqlMonitor"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
